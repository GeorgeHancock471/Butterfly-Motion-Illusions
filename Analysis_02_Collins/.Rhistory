model <- lmer(Forwards_Confusion ~ sex + (1|Binomial) ,
data = d)
summary(model)
hist(residuals(model))
qqnorm(residuals(model))     # Plots the residuals against a normal distribution
qqline(residuals(model))     # Adds a reference line for normality
