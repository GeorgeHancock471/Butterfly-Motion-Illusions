## FB, RenderColour & Forwards_Confusion ----
d=subset(dataSet, wing=="forewing" )
ggplot(d, aes(x = render_method, y = Forwards_Confusion, fill = render_method,
pattern = render_method)) +
geom_violin(alpha=0.5) +
geom_boxplot_pattern(
aes(pattern = render_method),
pattern_alpha = 0.4,      # Adjust stripe alpha
pattern_density = 0.5,    # Adjust stripe density
pattern_spacing = 0.02,   # Adjust stripe spacing
pattern_fill = "black",   # Color of stripes
pattern_color = "black"   # Stripe border color
) +
facet_grid(. ~ flight_method)+
scale_fill_manual(values = c("darkgray", "lightgray", "white")) +
scale_pattern_manual(values = c("none", "circle", "none")) +  # Apply stripes to the middle one
theme_light()
ggplot(d, aes(x = render_method, y = Forwards_Confusion, fill = render_method,
pattern = render_method)) +
geom_violin(alpha=0.5) +
geom_boxplot_pattern(width=0.25,
aes(pattern = render_method),
pattern_alpha = 0.4,      # Adjust stripe alpha
pattern_density = 0.5,    # Adjust stripe density
pattern_spacing = 0.02,   # Adjust stripe spacing
pattern_fill = "black",   # Color of stripes
pattern_color = "black"   # Stripe border color
) +
facet_grid(. ~ flight_method)+
scale_fill_manual(values = c("darkgray", "lightgray", "white")) +
scale_pattern_manual(values = c("none", "circle", "none")) +  # Apply stripes to the middle one
